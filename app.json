{
  "expo": {
    "name": "Internly OJT Tracker",
    "slug": "internly-ojt-tracker",
    "scheme": "internly",
    "version": "1.0.3",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/d329cb68-6a5f-4e21-8055-6ae62b0ea942"
    },
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.internly.ojttracker",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "internly"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "d329cb68-6a5f-4e21-8055-6ae62b0ea942"
      },
      "enableRemotePush": false
    },
    "plugins": [
      "expo-dev-client",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Internly to access your photos to set a profile picture."
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#7B68EE"
        }
      ],
      "expo-asset"
    ]
  }
}
