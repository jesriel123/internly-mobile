# Preferred redirect from Supabase password reset emails for mobile
# Production-first default
EXPO_PUBLIC_PASSWORD_RESET_WEB_URL=https://internly-web.vercel.app/reset-password

# LAN override example for local testing:
# EXPO_PUBLIC_PASSWORD_RESET_WEB_URL=http://192.168.68.114:3000/reset-password

# Direct deep link fallback (used only if WEB_URL is unavailable)
EXPO_PUBLIC_PASSWORD_RESET_REDIRECT=internly://login
