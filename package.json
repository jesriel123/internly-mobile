{
  "name": "internly-ojt-tracker",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "start:go": "expo start --go --lan --clear --port 8081",
    "start:hot": "cross-env EXPO_USE_POLLING=1 CHOKIDAR_USEPOLLING=1 expo start --go --lan --clear --port 8081",
    "start:hot:tunnel": "cross-env EXPO_USE_POLLING=1 CHOKIDAR_USEPOLLING=1 expo start --go --tunnel --clear --port 8081",
    "start:dev": "expo start --dev-client --lan --clear --port 8081",
    "start:hot:dev": "cross-env EXPO_USE_POLLING=1 CHOKIDAR_USEPOLLING=1 expo start --dev-client --lan --clear --port 8081",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "dev": "expo start --web",
    "dev:android": "expo start --android",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:bug-exploration": "jest auth-timeout-bug-exploration.test.js --runInBand",
    "web:vscode": "cross-env EXPO_USE_POLLING=1 CHOKIDAR_USEPOLLING=1 expo start --web --lan --clear --port 8082",
    "build:dev:android": "eas build --profile development --platform android",
    "build:preview:android": "eas build --profile preview --platform android",
    "build:prod:android": "eas build --profile production --platform android"
  },
  "dependencies": {
    "@expo/metro-runtime": "~5.0.5",
    "@expo/vector-icons": "^14.0.0",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-community/datetimepicker": "8.4.1",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "@supabase/supabase-js": "^2.99.1",
    "expo": "~53.0.0",
    "expo-asset": "~11.1.7",
    "expo-auth-session": "~6.2.1",
    "expo-constants": "~17.1.8",
    "expo-crypto": "~14.1.5",
    "expo-dev-client": "~5.2.4",
    "expo-device": "~7.1.4",
    "expo-font": "~13.3.2",
    "expo-image-picker": "~16.1.4",
    "expo-keep-awake": "~14.1.4",
    "expo-linear-gradient": "~14.1.5",
    "expo-notifications": "~0.31.5",
    "expo-status-bar": "~2.2.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-calendars": "^1.1314.0",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-paper": "^5.11.1",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-web": "^0.20.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/react": "^16.1.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.0.10",
    "babel-preset-expo": "~13.0.0",
    "cross-env": "^7.0.3",
    "fast-check": "^3.22.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "react-test-renderer": "19.0.0",
    "supabase": "^2.81.3",
    "typescript": "~5.8.3"
  },
  "private": true
}
